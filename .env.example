# Host folder with incoming JSONL files (mounted to /ubki-data in containers)
UBKI_DATA_FOLDER_PATH=/path/to/ubki-data

UBKI_LOGIN=
UBKI_PASSWORD=

# Production endpoints (defaults). For the test contour use:
#   UBKI_URL=https://test.ubki.ua/upload/data
#   UBKI_AUTH_URL=https://test.ubki.ua/b2_api_xml/ubki/auth
UBKI_URL=https://secure.ubki.ua/upload/data
UBKI_AUTH_URL=https://secure.ubki.ua/b2_api_xml/ubki/auth

# Static token required by POST endpoints (X-API-Token header)
API_TOKEN=

# Optional Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Only files matching this glob are picked up from the data folder (default *.txt).
FILE_GLOB=*.txt

# SQLite path inside the container; docker-compose sets it to /data/ubki.sqlite3.
DB_PATH=/data/ubki.sqlite3

# Auto-retry cap for `failed` records (default 5 passes).
RETRY_CAP=5

# Ignore files younger than this many seconds — half-written file guard (default 300).
MIN_FILE_AGE_SEC=300


MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DB=


# Enrichment: raw producer files + cabinet MySQL (read-only)
RAW_FOLDER=/ubki-data

# dir.15 collateral type injected into deals that lack it
DEAL_VIDOBES=90